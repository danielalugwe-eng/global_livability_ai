# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# NEVER commit .env to Git
# ─────────────────────────────────────────────────────────────────────────────

# AWS credentials (use IAM roles in production — only set here for local dev)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# S3 data lake bucket name (must match terraform/s3.tf)
DATA_BUCKET=gla-data-lake-dev

# MLflow tracking URI (local SQLite by default; point to remote server in prod)
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Slack webhook for Kestra notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# GitHub Actions secrets (set in repo Settings → Secrets)
# AWS_DEPLOY_ROLE_ARN=arn:aws:iam::123456789012:role/gla-github-deploy
