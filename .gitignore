
# ── Data & model artefacts (tracked by DVC, not Git) ─────────────────────────
data/raw/
data/processed/
data/features/
data/forecasts/
models/*.pkl
models/*.json
models/*.txt
app/assets/*.png

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Environment secrets ───────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Tooling ───────────────────────────────────────────────────────────────────
.DS_Store
optuna_study.db
mlflow.db
mlruns/
